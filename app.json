{
  "expo": {
    "name": "Haritham",
    "slug": "haritham",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "haritham",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "upi"
        ],
        "NSCameraUsageDescription": "Allow Haritham to access your camera for QR-based pickup verification.",
        "NSLocationWhenInUseUsageDescription": "Allow Haritham to access your location to set accurate pickup locations."
      }
    },
    "android": {
      "package": "com.sarodvs.haritham",
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "versionCode": 2
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/LOGO.png",
          "resizeMode": "contain",
          "backgroundColor": "#0b1120"
        }
      ],
      "expo-camera",
      "expo-location",
      "@react-native-community/datetimepicker"
    ],
    "assetBundlePatterns": [
      "assets/images/*"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "30e3dff4-ec52-4e9f-868b-830e2bac316d"
      },
      "router": {}
    },
    "owner": "sarodvs"
  }
}
